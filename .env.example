# Postgres (used by docker-compose)
POSTGRES_DB=wsb
POSTGRES_USER=wsb
POSTGRES_PASSWORD=wsb

# Connection string used by host-side tooling (psql, scripts).
# Inside compose, the web container reaches Postgres at hostname `postgres`.
DATABASE_URL=postgres://wsb:wsb@localhost:5432/wsb

# Optional override for the web container's DATABASE_URL. Leave unset to use
# the in-network default (postgres://...@postgres:5432/wsb).
# WEB_DATABASE_URL=

# Port the web service publishes on the host.
WEB_PORT=3000

# --- n8n (only needed if you bring up the optional `n8n` profile) ---
# N8N_PORT=5678
# N8N_HOST=wsb.example.com           # public hostname behind your reverse proxy
# N8N_PROTOCOL=https
# N8N_WEBHOOK_URL=https://wsb.example.com/n8n/
# Required if you start n8n in compose. Generate once with `openssl rand -hex 32`
# and KEEP IT — it encrypts saved credentials at rest.
# N8N_ENCRYPTION_KEY=

# Finnhub free tier: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# Anthropic key already lives in the n8n credential, but keep one here for any
# future host-side scripts.
ANTHROPIC_API_KEY=

# Server-wide timezone (affects n8n cron interpretation).
TZ=America/New_York
